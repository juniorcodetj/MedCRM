NODE_ENV=development

POSTGRES_USER=medcrm
POSTGRES_PASSWORD=medcrm_password
POSTGRES_DB=medcrm
DATABASE_URL=postgresql://medcrm:medcrm_password@postgres:5432/medcrm?schema=public

REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=medcrm_minio
MINIO_ROOT_PASSWORD=medcrm_minio_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=medcrm

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
FRONTEND_PORT=3002
AUTH_SERVICE_URL=http://auth-service:3001
AUTH_SERVICE_INTERNAL_URL=http://auth-service:3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_REALTIME_URL=http://localhost:3000
INTERNAL_API_URL=http://api-gateway:3000

COOKIE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:3002,http://localhost:3000

GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_AUTH_MAX=20
GATEWAY_RATE_LIMIT_PUBLIC_MAX=300
GATEWAY_RATE_LIMIT_INTERNAL_MAX=1000
GATEWAY_RATE_LIMIT_WEBSOCKET_MAX=120
